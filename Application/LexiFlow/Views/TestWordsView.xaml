<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:uc="clr-namespace:LexiFlow.Views.UserControls"
             x:Class="LexiFlow.Views.TestWordsView"
             Title="TestWords"
             Background="#222222">
    <Grid Padding="16" VerticalOptions="Center">
        <VerticalStackLayout Spacing="8"
                             HorizontalOptions="Center"
                             WidthRequest="{OnIdiom Phone=300, Default=460}">
            <Label Text="Remember 10 words." Style="{StaticResource Title}"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            <Label Text="if you reopen this form, reset the problems." TextColor="Gray"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,20">
                <Label x:Name="display" FontSize="20" HorizontalTextAlignment="Center"
                       VerticalOptions="Center" Margin="10"/>
                <Grid IsVisible="false" x:Name="wrong" VerticalOptions="Center">
                    <Ellipse Fill="Red" WidthRequest="20" HeightRequest="20"/>
                    <Label Text="✕" TextColor="White" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>
            </HorizontalStackLayout>

            <Entry x:Name="answer" FontSize="18" HorizontalOptions="Fill"
                   Placeholder="Enter your answer" Completed="OnEntryCompleted"/>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,8,0,0">
                <Button Grid.Column="0" Text="Submit" Clicked="OnSubmitClick" FontSize="13" HorizontalOptions="Fill"/>
                <Button Grid.Column="1" Text="Next" Clicked="OnNextClick" FontSize="13" HorizontalOptions="Fill"/>
                <Button Grid.Column="2" Text="Check" Clicked="OnCheckClick" FontSize="13" HorizontalOptions="Fill"/>
            </Grid>

            <CollectionView x:Name="results" HeightRequest="200" HorizontalOptions="Fill" Margin="0,10,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <uc:WordControl BindingContext="{Binding}"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </Grid>
</ContentPage>