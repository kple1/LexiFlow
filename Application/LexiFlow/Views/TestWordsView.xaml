<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:uc="clr-namespace:LexiFlow.Views.UserControls"
             x:Class="LexiFlow.Views.TestWordsView"
             Title="TestWords"
             Background="#222222">
    <Grid HorizontalOptions="Center" VerticalOptions="Center">
        <VerticalStackLayout>
            <Label Text="Remember 10 words." Style="{StaticResource Title}" HorizontalOptions="Center"/>
            <Label Text="if you reopen this form, reset the problems." TextColor="Gray" HorizontalOptions="Center"/>
            <VerticalStackLayout Margin="30">
                
                <Grid HorizontalOptions="Center">
                    <HorizontalStackLayout>
                        <Label x:Name="display" FontSize="20" HorizontalTextAlignment="Center" Margin="30"/>
                        <Grid IsVisible="false" x:Name="wrong">
                            <Ellipse Fill="Red" WidthRequest="20" HeightRequest="20"/>
                            <Label Text="✕" TextColor="White" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>
                    </HorizontalStackLayout>
                </Grid>

                <Entry x:Name="answer" FontSize="18" WidthRequest="380" HorizontalOptions="Center" Placeholder="Enter your answer" Completed="OnEntryCompleted"/>

                <Grid HorizontalOptions="Center">
                    <HorizontalStackLayout>
                        <Button Text="Submit" Clicked="OnSubmitClick" WidthRequest="120" Margin="5"/>
                        <Button Text="Next" Clicked="OnNextClick" WidthRequest="120" Margin="5"/>
                        <Button Text="CheckAnswer" Clicked="OnCheckClick" WidthRequest="120" Margin="5"/>
                    </HorizontalStackLayout>
                </Grid>

                <CollectionView x:Name="results" HeightRequest="200">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <uc:WordControl BindingContext="{Binding}"/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </Grid>
</ContentPage>