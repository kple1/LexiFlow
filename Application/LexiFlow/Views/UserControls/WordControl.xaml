<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LexiFlow.Views.UserControls.WordControl">
        <VerticalStackLayout Margin="10" HeightRequest="70">
            <Label Text="{Binding English}" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" BindingContext="{Binding}"
                       x:Name="word"/>
            <Label Text="{Binding Meaning}" FontSize="16" TextColor="Gray" HorizontalOptions="Center"/>
        </VerticalStackLayout>
</ContentView>
