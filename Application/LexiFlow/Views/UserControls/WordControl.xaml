<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:LexiFlow.Converters"
             x:Class="LexiFlow.Views.UserControls.WordControl">
    <ContentView.Resources>
        <conv:StatusColorConverter x:Key="StatusColor"/>
    </ContentView.Resources>
    <VerticalStackLayout Margin="10" Spacing="2">
        <Label Text="{Binding English}" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" x:Name="word"/>
        <Label Text="{Binding Meaning}" FontSize="16" TextColor="Gray" HorizontalOptions="Center"/>
        <Border IsVisible="{Binding HasUserStatus}" HorizontalOptions="Center" Padding="8,1" StrokeThickness="0"
                BackgroundColor="{Binding UserStatus, Converter={StaticResource StatusColor}}"
                StrokeShape="RoundRectangle 8">
            <Label Text="{Binding UserStatus}" FontSize="11" TextColor="White"/>
        </Border>
    </VerticalStackLayout>
</ContentView>
