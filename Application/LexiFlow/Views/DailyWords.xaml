<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:uc="clr-namespace:LexiFlow.Views.UserControls"
             x:Class="LexiFlow.Views.DailyWords"
             Title="Daily Words">
    <CollectionView x:Name="WordsView">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <uc:WordControl BindingContext="{Binding}"/>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
    
</ContentPage>