<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LexiFlow.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:LexiFlow"
    xmlns:view="clr-namespace:LexiFlow.Views"
    Title="LexiFlow">

    <ShellContent
        Title="AllWorlds"
        ContentTemplate="{DataTemplate view:DailyWords}"
        Route="DailyWordsPage" />
    <ShellContent
        Title="TestWords"
        ContentTemplate="{DataTemplate view:TestWords}"
        Route="TestWordsPage" />
    <!--<ShellContent
        Title="DailyWord"
        ContentTemplate="{DataTemplate view:DailyWords}"
        Route="DailyWordsPage" />-->

</Shell>